# ─── Domain ──────────────────────────────────────────────────────────────────
# Production: your-domain.com  |  Local: localhost
DOMAIN=localhost

# ─── Internal container ports ────────────────────────────────────────────────
PORT_NGINX=80
PORT_LANDING=3000
PORT_ADMIN=3001
PORT_SUPPORT=3002
PORT_BACKEND=4000

# ─── Database (only reachable by the backend container) ──────────────────────
DB_NAME=links
DB_USER=links
DB_PASSWORD=changeme
DB_HOST=postgres
DB_PORT=5432
# !! Werte oben spiegeln \u2013 bei \u00c4nderung auch hier aktualisieren
DATABASE_URL=postgres://links:changeme@postgres:5432/links?sslmode=disable

# ─── App environment ──────────────────────────────────────────────────────────
APP_ENV=development

# ─── Public variables (exposed to the browser via SvelteKit) ─────────────────
# Variables starting with PUBLIC_ are forwarded to the client bundle.
PUBLIC_API_URL=http://localhost:4000